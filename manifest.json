{
  "manifest_version": 3,
  "name": "Firki - AI-Powered Recruitment Assistant",
  "version": "2.0.0",
  "description": "Intelligent job description analysis and LinkedIn boolean search generation powered by AI",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://mail.google.com/*",
    "https://www.linkedin.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*", "https://www.linkedin.com/jobs/*"],
      "js": ["config.js", "analytics.js", "backend-connector.js", "auth.js", "intelligent-jd-parser.js", "skill-context-helper.js", "gemini-context-analyzer.js", "boolean-search.js", "ui.js", "content.js"],
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Firki - AI Recruitment Assistant"
  },
  "icons": {
    "16": "icons/icon.svg",
    "48": "icons/icon.svg",
    "128": "icons/icon.svg"
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/*"],
      "matches": ["<all_urls>"]
    }
  ]
} 